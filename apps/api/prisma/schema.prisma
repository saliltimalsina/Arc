generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String
  passwordHash    String
  emailVerified   Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  ownedProjects   Project[]       @relation("OwnedProjects")
  memberships     ProjectMember[]
  teamMemberships TeamMember[]
  itemAssignments ItemAssignee[]
  comments        Comment[]
}

model Team {
  id        String       @id @default(cuid())
  name      String
  emoji     String       @default("🏢")
  color     String       @default("#338EF7")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  members   TeamMember[]
  projects  Project[]
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@index([teamId])
}

model Project {
  id          String          @id @default(cuid())
  name        String
  emoji       String          @default("🚀")
  color       String          @default("#338EF7")
  client      String          @default("Internal")
  status      String          @default("active")
  description String?
  ownerId     String
  teamId      String?
  owner       User            @relation("OwnedProjects", fields: [ownerId], references: [id])
  team        Team?           @relation(fields: [teamId], references: [id])
  members     ProjectMember[]
  sprints     Sprint[]
  items       Item[]
  milestones  Milestone[]
  goals       Goal[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([ownerId])
  @@index([teamId])
}

model Milestone {
  id        String   @id @default(cuid())
  projectId String
  name      String
  date      DateTime
  position  Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model Goal {
  id        String   @id @default(cuid())
  projectId String
  name      String
  emoji     String   @default("🎯")
  color     String   @default("#338EF7")
  startDate DateTime
  endDate   DateTime
  position  Int      @default(0)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String  @default("member")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

model Sprint {
  id        String    @id @default(cuid())
  projectId String
  name      String
  goal      String?
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("planned")
  position  Int       @default(0)
  items     Item[]
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([projectId])
}

model Item {
  id          String         @id @default(cuid())
  projectId   String
  sprintId    String?
  parentId    String?
  title       String
  description String?
  type        String         @default("story")
  status      String         @default("To Do")
  priority    String         @default("medium")
  points      Int?
  dueDate     DateTime?
  position    Int            @default(0)
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint      Sprint?        @relation(fields: [sprintId], references: [id])
  parent      Item?          @relation("Subtasks", fields: [parentId], references: [id])
  subtasks    Item[]         @relation("Subtasks")
  assignees   ItemAssignee[]
  comments    Comment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([projectId])
  @@index([sprintId])
  @@index([parentId])
  @@index([projectId, sprintId])
}

model ItemAssignee {
  id     String @id @default(cuid())
  itemId String
  userId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  itemId    String
  authorId  String
  body      String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([itemId])
  @@index([authorId])
}
