generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String
  passwordHash    String
  emailVerified   Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  ownedProjects   Project[]       @relation("OwnedProjects")
  memberships     ProjectMember[]
  itemAssignments ItemAssignee[]
  comments        Comment[]
}

model Project {
  id        String          @id @default(cuid())
  name      String
  emoji     String          @default("🚀")
  color     String          @default("#338EF7")
  client    String          @default("Internal")
  status    String          @default("active")
  ownerId   String
  owner     User            @relation("OwnedProjects", fields: [ownerId], references: [id])
  members   ProjectMember[]
  sprints   Sprint[]
  items     Item[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model ProjectMember {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String  @default("member")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Sprint {
  id        String    @id @default(cuid())
  projectId String
  name      String
  goal      String?
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("planned")
  position  Int       @default(0)
  items     Item[]
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Item {
  id          String         @id @default(cuid())
  projectId   String
  sprintId    String?
  parentId    String?
  title       String
  description String?
  type        String         @default("story")
  status      String         @default("To Do")
  priority    String         @default("medium")
  points      Int?
  position    Int            @default(0)
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprint      Sprint?        @relation(fields: [sprintId], references: [id])
  parent      Item?          @relation("Subtasks", fields: [parentId], references: [id])
  subtasks    Item[]         @relation("Subtasks")
  assignees   ItemAssignee[]
  comments    Comment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ItemAssignee {
  id     String @id @default(cuid())
  itemId String
  userId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([itemId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  itemId    String
  authorId  String
  body      String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
